import java.util.Scanner;
class Agente 
{
    protected int id;
    protected String nombre;
    protected String agencia;
    protected String rango;
    public Agente() 
    {
        Scanner teclado = new Scanner(System.in);

        System.out.println("\n--- Registrar Agente ---");

        System.out.print("ID del agente: ");
        this.id = teclado.nextInt();
        teclado.nextLine();

        System.out.print("Nombre del agente: ");
        this.nombre = teclado.nextLine();

        System.out.print("Agencia: ");
        this.agencia = teclado.nextLine();

        System.out.print("Rango: ");
        this.rango = teclado.nextLine();
    }
    public void reportar() 
    {
       System.out.println(" " + nombre + " reporta a " + agencia);
    }

    public String obtenerInfo()
    {
        return nombre + " [" + rango + "]";
    }
}
class Espia
{

    protected String nombreClave;
    protected String zonaVigilada;
    protected int horaInicio;

    public Espia(String nombreClave, String zonaVigilada, int horaInicio)
    {

        this.nombreClave = nombreClave;
        this.zonaVigilada = zonaVigilada;
        this.horaInicio = horaInicio;
    }

    public void reportarTurno()
    {

        System.out.println(
                "El agente " + nombreClave
                + " vigila la zona "
                + zonaVigilada
                + " desde las "
                + horaInicio + ":00 horas");
    }

    public String obtenerInfo()
    {

        return nombreClave + " [Espía nocturno]";
    }
}


class Policia
{
    protected int id;
    protected String nombre;
    protected String apellido;
    protected String rango;
    protected String interrogatorio;

    public Policia() 
    {

        Scanner teclado = new Scanner(System.in);

        System.out.println("\n--- Registrar Policía ---");

        System.out.print("ID del policía: ");
